# Environment
NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/guide_on_phone

# JWT
JWT_ACCESS_SECRET=your_access_secret_key_min_16_chars
JWT_REFRESH_SECRET=your_refresh_secret_key_min_16_chars
JWT_ACCESS_EXP=15m
JWT_REFRESH_EXP=7d

# Client URL
CLIENT_URL=http://localhost:3000

# Aadhaar Encryption Key (32 bytes for AES-256)
AADHAAR_ENCRYPTION_KEY=your_32_byte_encryption_key

# KYC Provider - For Aadhaar OTP (Signzy, HyperVerge, etc.)
# Options: mock, live
KYC_PROVIDER_MODE=live
KYC_PROVIDER_URL=https://api.provider.co/in/aadhaar/generate-otp
KYC_PROVIDER_API_KEY=your_kyc_provider_api_key

# Face Verification Provider - For face matching AI
# Options: mock, live
FACE_PROVIDER_MODE=live
FACE_PROVIDER_URL=https://api.provider.co/in/face/live-match
FACE_PROVIDER_API_KEY=your_face_provider_api_key

# GST Provider - For GST validation
# Options: mock, live
GST_PROVIDER_MODE=live
GST_PROVIDER_URL=https://api.provider.co/in/gst/verify
GST_PROVIDER_API_KEY=your_gst_provider_api_key

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=xxx
PLATFORM_COMMISSION_PERCENT=10

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user
SMTP_PASS=pass

# SMS (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# Firebase
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase@example.com
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
